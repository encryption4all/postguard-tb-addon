{
  "name": "postguard-tb-addon",
  "version": "0.8.2",
  "private": true,
  "description": "PostGuard encryption extension for Thunderbird",
  "scripts": {
    "build": "node build.mjs",
    "build:dev": "node build.mjs --dev",
    "watch": "node build.mjs --dev --watch",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "package": "npm run build && cd dist && zip -r ../postguard-tb-addon-$(node -p \"require('../package.json').version\").xpi ."
  },
  "devDependencies": {
    "dotenv": "^17.4.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@e4a/pg-js": "^0.7.0"
  }
}
