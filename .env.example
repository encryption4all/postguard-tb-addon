# PostGuard Thunderbird Add-on — Build-time Configuration
# Copy this file to .env and adjust as needed.

# PostGuard Key Generation server URL
PKG_URL=https://staging.postguard.eu/pkg

# Cryptify file storage and delivery service URL
CRYPTIFY_URL=https://fileshare.staging.postguard.eu

# PostGuard website URL (used for browser-based decryption fallback)
POSTGUARD_WEBSITE_URL=https://staging.postguard.eu
